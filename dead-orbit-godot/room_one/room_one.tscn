[sub_resource type="GDScript" id="GDScript_electric_charge"]
script/source = "extends Area2D

@export var move_distance: float = 480.0
@export var move_speed: float = 0.9
@export var respawn_position: Vector2 = Vector2(280, 539)

var start_position: Vector2
var elapsed: float = 0.0

func _ready() -> void:
	start_position = global_position
	body_entered.connect(_on_body_entered)

func _process(delta: float) -> void:
	elapsed += delta
	global_position.x = start_position.x + sin(elapsed * move_speed) * move_distance

func _on_body_entered(body: Node) -> void:
	if body is CharacterBody2D:
		body.global_position = respawn_position
		body.velocity = Vector2.ZERO
"

